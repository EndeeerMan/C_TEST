{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MinGW GDB 调试",
            "type": "cppdbg",
            "request": "launch",
            // 路径统一使用正斜杠 /，且去掉 output 文件夹
            "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc.exe 生成活动文件"
        }
    ]
}